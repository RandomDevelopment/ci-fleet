# Copy to /etc/ci-fleet/ci-fleet.env and chmod 0600.
# This file contains identifiers and settings, not private keys or project secrets.
CI_FLEET_GITHUB_URL=https://github.com/EXAMPLE-ORG
CI_FLEET_SCALE_SET_NAME=docker-ci-home-ci-01
CI_FLEET_LABELS=docker-ci-experimental
CI_FLEET_RUNNER_GROUP=trusted-private-ci
CI_FLEET_INSTANCE=home-ci-01
CI_FLEET_GITHUB_APP_CLIENT_ID=Iv1.EXAMPLE
CI_FLEET_GITHUB_APP_INSTALLATION_ID=12345678
CI_FLEET_GITHUB_APP_PRIVATE_KEY_FILE=/etc/ci-fleet/secrets/github-app.pem
CI_FLEET_DOCKER_GID=998
CI_FLEET_MIN_RUNNERS=0
CI_FLEET_MAX_RUNNERS=1
CI_FLEET_RUNNER_CPUS=4
CI_FLEET_RUNNER_MEMORY_MIB=8192
CI_FLEET_RUNNER_TTL=6h
CI_FLEET_RUNNER_IMAGE=ci-fleet-runner:dev
CI_FLEET_CONTROLLER_IMAGE=ci-fleet-controller:dev
