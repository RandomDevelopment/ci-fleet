# Copy to /etc/ci-fleet/host.env and set mode 0600.
# These values stay on the controller host and are never rendered from Git.
# The private key itself must be root-owned mode 0600 at the path below.

CI_FLEET_GITHUB_APP_CLIENT_ID=Iv1.EXAMPLE
CI_FLEET_GITHUB_APP_INSTALLATION_ID=12345678
CI_FLEET_GITHUB_APP_PRIVATE_KEY_FILE=/etc/ci-fleet/secrets/github-app.pem
CI_FLEET_RUNNER_TTL=6h
